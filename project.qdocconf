project = WareLog
description = An app for entering a catalogue of items, for items that can be measured in grams, liters etc.

sourcedirs = ./doc/tutorial-files

sources.fileextensions = "*.qdoc"

outputdir = doc/tutorial
outputformats = HTML
HTML.stylesheets = doc/tutorial-files/template/style/style.css
HTML.headerstyles = "<link rel=\"stylesheet\" type=\"text/css\" href=\"style/style.css\"/>\n"
